# testy: runtime + pytest + pytest-cov
FROM python:3.10-slim AS test

WORKDIR /app

COPY requirements.txt requirements-test.txt ./
RUN pip install --no-cache-dir \
    -r requirements.txt \
    -r requirements-test.txt

COPY . .

# nadpisywane przez docker-compose.test.yml
CMD ["pytest", "test_app.py", "-v", "--tb=short"]
